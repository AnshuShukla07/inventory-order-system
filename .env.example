# Database credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory_db

# Backend database connection string (used when running backend directly)
# Local PostgreSQL option:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inventory_db

# Local SQLite option (for quick testing outside Docker):
# DATABASE_URL=sqlite:///./inventory.db

# Frontend configurations (Vite)
VITE_API_URL=http://localhost:8000/api
